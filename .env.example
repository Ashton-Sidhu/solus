# Optional analytics. Leave unset to disable PostHog capture.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Optional Google Docs/Drive integration.
# Google desktop OAuth clients require both values at build time.
SOLUS_GOOGLE_CLIENT_ID=
SOLUS_GOOGLE_CLIENT_SECRET=

# Optional GitHub integration (PR review).
# OAuth App device flow needs only the client ID — no secret is shipped.
SOLUS_GITHUB_CLIENT_ID=

# Required only when producing signed/notarized macOS release builds.
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
